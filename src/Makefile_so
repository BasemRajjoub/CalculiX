
CFLAGS = -Wall -g -fPIC -I ../../SPOOLES.2.2 -DARCH="Linux" -DSPOOLES -DARPACK -DMATRIXSTORAGE -DNETWORKOUT
FFLAGS = -Wall -g -fPIC -cpp -fallow-argument-mismatch

CC=cc
FC=gfortran

.c.o :
	$(CC) $(CFLAGS) -c $<
.f.o :
	$(FC) $(FFLAGS) -c $<

include Makefile.inc

SCCXMAIN = CalculiX_so.c

OCCXF = $(SCCXF:.f=.o)
OCCXC = $(SCCXC:.c=.o)
OCCXMAIN = $(SCCXMAIN:.c=.o)

DIR=../../SPOOLES.2.2

LIBS = \
       $(DIR)/spooles.a \
       /usr/lib64/liblapack.a \
       -lblas \
       -larpack \
       -lpthread -lm -lc

libcalculix.so: $(OCCXMAIN) CalculiX_so.a $(LIBS)
	./date.pl; $(CC) $(CFLAGS) -c CalculiX_so.c; $(FC) -shared -fPIC -Wall -g -o $@ $(OCCXMAIN) CalculiX_so.a  $(LIBS) -fopenmp

CalculiX_so.a: $(OCCXF) $(OCCXC)
	ar vr $@ $?
